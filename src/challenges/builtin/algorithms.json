      { "name": "found at end", "setup": "", "run": "result = binary_search([1,2,3], 3)", "assert": "result == 2" },
      { "name": "not found", "setup": "", "run": "result = binary_search([1,2,3], 4)", "assert": "result == -1" },
      { "name": "empty array", "setup": "", "run": "result = binary_search([], 1)", "assert": "result == -1" },
      { "name": "single element found", "setup": "", "run": "result = binary_search([5], 5)", "assert": "result == 0" }
