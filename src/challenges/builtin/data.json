    "category": "data-structures",
    "difficulty": "medium",
    "prompt": "Implement a Trie class with insert(word), search(word) -> bool, starts_with(prefix) -> bool, and autocomplete(prefix) -> list of words with that prefix.",
    "language": "python",
    "tests": [
      { "name": "insert and search", "setup": "t = Trie()", "run": "t.insert('hello'); result = t.search('hello')", "assert": "result == True" },
      { "name": "search missing", "setup": "t = Trie()", "run": "t.insert('hello'); result = t.search('hell')", "assert": "result == False" },
      { "name": "starts_with", "setup": "t = Trie()", "run": "t.insert('hello'); result = t.starts_with('hel')", "assert": "result == True" },
      { "name": "autocomplete", "setup": "t = Trie()", "run": "t.insert('hello'); t.insert('help'); t.insert('world'); result = sorted(t.autocomplete('hel'))", "assert": "result == ['hello', 'help']" },
      { "name": "empty autocomplete", "setup": "t = Trie()", "run": "t.insert('hello'); result = t.autocomplete('xyz')", "assert": "result == []" }
