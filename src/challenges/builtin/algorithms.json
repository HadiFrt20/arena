  {
    "id": "lru-cache",
    "title": "LRU Cache with O(1) Operations",
    "category": "algorithms",
    "difficulty": "medium",
    "prompt": "Implement an LRUCache class with capacity, get(key), and put(key, value) methods. get returns -1 if key not found. Both operations should be O(1). When capacity is exceeded, evict the least recently used key.",
    "language": "python",
    "tests": [
      { "name": "basic put and get", "setup": "cache = LRUCache(2)", "run": "cache.put(1, 1); result = cache.get(1)", "assert": "result == 1" },
      { "name": "get missing key", "setup": "cache = LRUCache(2)", "run": "result = cache.get(99)", "assert": "result == -1" },
      { "name": "eviction", "setup": "cache = LRUCache(2)", "run": "cache.put(1, 1); cache.put(2, 2); cache.put(3, 3); result = cache.get(1)", "assert": "result == -1" },
      { "name": "access refreshes", "setup": "cache = LRUCache(2)", "run": "cache.put(1, 1); cache.put(2, 2); cache.get(1); cache.put(3, 3); result = cache.get(2)", "assert": "result == -1" },
      { "name": "overwrite key", "setup": "cache = LRUCache(2)", "run": "cache.put(1, 1); cache.put(1, 10); result = cache.get(1)", "assert": "result == 10" }
    ],
    "qualitative_checks": [
      { "id": "doubly-linked", "description": "Uses doubly linked list or OrderedDict", "patterns": ["OrderedDict", "prev.*next|next.*prev"] },
      { "id": "type-hints", "description": "Includes type hints", "patterns": ["def .+\\(.*:.*\\).*->"] },
      { "id": "docstrings", "description": "Includes docstrings", "patterns": ["\"\"\"", "'''"] }
    ]
  },
