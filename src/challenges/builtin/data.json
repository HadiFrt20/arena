  {
    "id": "graph-bfs",
    "title": "BFS Shortest Path",
    "category": "data-structures",
    "difficulty": "medium",
    "prompt": "Write a function shortest_path(graph, start, end) that finds the shortest path in an unweighted graph. The graph is an adjacency list (dict of node -> list of neighbors). Return the path as a list of nodes, or an empty list if no path exists.",
    "language": "python",
    "tests": [
      { "name": "direct path", "setup": "g = {'A': ['B'], 'B': ['A', 'C'], 'C': ['B']}", "run": "result = shortest_path(g, 'A', 'C')", "assert": "result == ['A', 'B', 'C']" },
      { "name": "same node", "setup": "g = {'A': ['B'], 'B': ['A']}", "run": "result = shortest_path(g, 'A', 'A')", "assert": "result == ['A']" },
      { "name": "no path", "setup": "g = {'A': ['B'], 'B': ['A'], 'C': []}", "run": "result = shortest_path(g, 'A', 'C')", "assert": "result == []" },
      { "name": "shortest of multiple", "setup": "g = {'A': ['B', 'C'], 'B': ['A', 'D'], 'C': ['A', 'D'], 'D': ['B', 'C']}", "run": "result = shortest_path(g, 'A', 'D')", "assert": "len(result) == 3" }
    ],
