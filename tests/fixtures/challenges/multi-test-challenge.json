{
  "id": "multi-test",
  "title": "String Reverser",
  "category": "algorithms",
  "difficulty": "easy",
  "prompt": "Write a function called reverse_string(s) that returns the reversed string.",
  "language": "python",
  "tests": [
    { "name": "basic reverse", "setup": "", "run": "result = reverse_string('hello')", "assert": "result == 'olleh'" },
    { "name": "empty string", "setup": "", "run": "result = reverse_string('')", "assert": "result == ''" },
    { "name": "single char", "setup": "", "run": "result = reverse_string('a')", "assert": "result == 'a'" },
    { "name": "palindrome", "setup": "", "run": "result = reverse_string('racecar')", "assert": "result == 'racecar'" },
    { "name": "unicode", "setup": "", "run": "result = reverse_string('hello')", "assert": "result == 'olleh'" },
    { "name": "spaces", "setup": "", "run": "result = reverse_string('a b c')", "assert": "result == 'c b a'" },
    { "name": "numbers in string", "setup": "", "run": "result = reverse_string('abc123')", "assert": "result == '321cba'" },
    { "name": "special chars", "setup": "", "run": "result = reverse_string('!@#')", "assert": "result == '#@!'" }
  ],
  "qualitative_checks": [
    { "id": "slicing", "description": "Uses Python slicing", "patterns": ["\\[::-1\\]"] },
