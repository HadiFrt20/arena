  {
    "id": "rate-limiter",
    "title": "Token Bucket Rate Limiter",
    "category": "algorithms",
    "difficulty": "hard",
    "prompt": "Implement a TokenBucketRateLimiter class with __init__(self, capacity, refill_rate) where refill_rate is tokens per second. Implement allow(self) that returns True if a request is allowed (consuming one token) or False if the bucket is empty. Tokens refill over time based on elapsed time since last check.",
    "language": "python",
    "tests": [
      { "name": "allows up to capacity", "setup": "rl = TokenBucketRateLimiter(3, 1)", "run": "results = [rl.allow() for _ in range(3)]; result = all(results)", "assert": "result == True" },
      { "name": "blocks after capacity", "setup": "rl = TokenBucketRateLimiter(2, 1)", "run": "rl.allow(); rl.allow(); result = rl.allow()", "assert": "result == False" },
      { "name": "refills over time", "setup": "import time; rl = TokenBucketRateLimiter(1, 10)", "run": "rl.allow(); time.sleep(0.2); result = rl.allow()", "assert": "result == True" },
      { "name": "zero capacity", "setup": "rl = TokenBucketRateLimiter(0, 1)", "run": "result = rl.allow()", "assert": "result == False" }
    ],
    "qualitative_checks": [
      { "id": "time-based", "description": "Uses time module for refill", "patterns": ["time\\.time|time\\.monotonic"] },
      { "id": "thread-safe", "description": "Uses threading locks", "patterns": ["Lock\\(\\)", "threading"] },
      { "id": "type-hints", "description": "Includes type hints", "patterns": ["def .+\\(.*:.*\\).*->"] }
    ]
