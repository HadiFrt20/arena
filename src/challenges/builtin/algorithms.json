      { "name": "fizzbuzz(5)", "setup": "", "run": "result = fizzbuzz(5)", "assert": "result == ['1', '2', 'Fizz', '4', 'Buzz']" },
      { "name": "fizzbuzz(15) last element", "setup": "", "run": "result = fizzbuzz(15)", "assert": "result[-1] == 'FizzBuzz'" },
